{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/bootstrap.sh >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git push:*)",
      "Bash(./scripts/bootstrap.sh)",
      "Bash(./scripts/test.sh)",
      "Bash(./scripts/lint.sh)",
      "Bash(./scripts/check-changelog.sh:*)",
      "Bash(scripts/codex-review.sh:*)"
    ],
    "deny": [
      "Read(./offline/**)",
      "Read(./.env)",
      "Read(./**/*.pem)",
      "Read(./**/secrets/**)"
    ]
  }
}
