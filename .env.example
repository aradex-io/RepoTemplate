# Copy to .env and fill in. .env is git-ignored; never commit real secrets.
# Document every variable the project needs here with a safe placeholder.

# Example:
# DATABASE_URL=postgres://user:pass@localhost:5432/dbname
# API_KEY=changeme

# Used by scripts/codex-review.sh to pick the Codex model (optional).
# CODEX_REVIEW_MODEL=gpt-5.3-codex
